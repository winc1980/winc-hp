# Notion API 環境変数設定テンプレート

# Notion Integration API Secret
# https://www.notion.so/my-integrations から生成
NOTION_API_SECRET=your_notion_api_secret_here

# ブログ投稿用データベースID
# Notion データベースのURLから取得: https://notion.so/workspace/[DATABASE_ID]?v=[VIEW_ID]
NOTION_DATABASE_ID=your_blog_database_id_here

# 著者情報用データベースID（オプション）
NOTION_DATABASE_ID_AUTHOR=your_author_database_id_here

# カスタムドメイン（オプション）
CUSTOM_DOMAIN=https://example.com

# ベースパス（オプション）
BASE_PATH=/blog

# Google Analytics トラッキングID（オプション）
NEXT_PUBLIC_GA_TRACKING_ID=your_ga_tracking_id_here

# APIリクエストのタイムアウト時間（ミリ秒）
REQUEST_TIMEOUT_MS=30000

# ライトボックス機能の有効/無効
NEXT_PUBLIC_ENABLE_LIGHTBOX=true
